# syntax=docker/dockerfile:1
#
# mkvhelper one-stop dependency container.
#
# Bundles every external tool mkvhelper shells out to, built from source
# against pinned upstream releases:
#
#   - libvmaf (with CUDA)               — the libvmaf_cuda filter, used by
#                                         the GPU VMAF tuning path.
#   - FFmpeg (CUDA + full codec set)    — NVENC/NVDEC, libvmaf_cuda,
#                                         software AV1 (libaom + libdav1d),
#                                         x264/x265/vpx, libnpp, zscale,
#                                         and the usual audio/subtitle
#                                         codecs.
#   - MKVToolNix (mkvextract, mkvmerge) — used by `mkvhelper split` and
#                                         `mkvhelper print-chapters`.
#
# All upstream versions are pinned via build args.  Bump VMAF_TAG /
# FFMPEG_TAG / NV_CODEC_TAG together when refreshing.
#
# HDR tonemap for VMAF runs on CPU via `zscale → tonemap`.  We tested
# `tonemap_cuda` (jellyfin-ffmpeg fork) and `tonemap_opencl` and found
# both unworkable end-to-end: tonemap_cuda breaks the libvmaf_cuda chain
# after the first frame (hwframes context mismatch), and tonemap_opencl
# does not accept p010 / 10-bit input on NVIDIA's ICD.  The win we
# wanted — moving VMAF off CPU — is fully captured by `libvmaf_cuda`
# itself, which dominates the perceptual-math cost; the zscale+tonemap
# prep is cheap by comparison.
#
# Base image is the NVIDIA CUDA devel image because its toolchain ships
# nvcc + the CUDA dev headers/libs at the standard `/usr/local/cuda`
# location.  CPATH/LIBRARY_PATH are exported below so downstream
# `./configure` and meson invocations auto-discover CUDA headers + libs
# without needing per-call --extra-cflags/--extra-ldflags.

FROM docker.io/nvidia/cuda:12.8.1-devel-ubuntu24.04

ARG VMAF_TAG=v3.1.0
ARG FFMPEG_TAG=n8.1.1
# nv-codec-headers commit pin.  libvmaf v3.1.0 uses functions on the
# `CudaFunctions` dynamic-loader struct (cuCtxGetStreamPriorityRange,
# cuStreamCreateWithPriority, cuCtxSynchronize, cuMemHostAlloc/FreeHost,
# cuMemFreeAsync) that the n13.x tag of nv-codec-headers stopped
# exposing — n13 trimmed the loader to "what ffmpeg actually needs,"
# breaking out-of-tree consumers like libvmaf.  This commit is what
# upstream Netflix/vmaf v3.1.0 itself tested against in their
# Dockerfile.ffmpeg, so we know the function set matches.
ARG NV_CODEC_TAG=876af32a202d0de83bd1d36fe74ee0f7fcf86b0d

# NVCC target: single-arch, PTX-only.
#
# PTX from compute_75 (Turing) is forward-compatible and JITs to native
# code on any GPU sm_75+ (Turing → Blackwell → future) at first kernel
# launch.  Single-arch is mandatory because FFmpeg's configure check
# runs `nvcc … -ptx` which is incompatible with multi-arch flags.  The
# JIT is one-time per container start and gets cached in the GPU
# driver's compute cache afterwards.
ARG NVCC_FLAGS="-gencode arch=compute_75,code=compute_75 -O2"

# Make CUDA headers + libs auto-discoverable by gcc/ld so downstream
# build systems don't have to pass --extra-cflags=-I/usr/local/cuda/include
# etc.  The nvidia/cuda devel image populates these paths but doesn't
# wire them into the toolchain's default search lists.
ENV CPATH=/usr/local/cuda/include
ENV LIBRARY_PATH=/usr/local/cuda/lib64
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH}
ENV PATH=/usr/local/cuda/bin:${PATH}

# Combined apt install: build tooling, FFmpeg codec deps, MKVToolNix.
# `--no-install-recommends` keeps the image lean.
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        # Build tooling
        build-essential \
        ca-certificates \
        git \
        meson \
        nasm \
        ninja-build \
        pkg-config \
        python3 \
        python3-pip \
        python3-venv \
        wget \
        xxd \
        # FFmpeg codec / format dev libs
        libaom-dev \
        libass-dev \
        libdav1d-dev \
        libfreetype6-dev \
        libfribidi-dev \
        libmp3lame-dev \
        libopus-dev \
        libtheora-dev \
        libvorbis-dev \
        libvpx-dev \
        libwebp-dev \
        libx264-dev \
        libx265-dev \
        libzimg-dev \
        # MKVToolNix CLI tools (mkvextract, mkvmerge, mkvinfo, ...)
        mkvtoolnix \
    && rm -rf /var/lib/apt/lists/*

# nv-codec-headers — required for FFmpeg's NVENC/NVDEC support.  Pinned.
RUN cd /tmp \
    && wget -q "https://github.com/FFmpeg/nv-codec-headers/archive/${NV_CODEC_TAG}.tar.gz" \
    && tar xf "${NV_CODEC_TAG}.tar.gz" \
    && cd nv-codec-headers-* \
    && make install \
    && cd /tmp && rm -rf nv-codec-headers-* "${NV_CODEC_TAG}.tar.gz"

# libvmaf with CUDA support, pinned.  meson auto-detects CUDA via the
# CPATH/LIBRARY_PATH env vars exported above.
#
# enable_tools=false disables the standalone `vmaf` CLI binary.  We don't
# use it — FFmpeg's libvmaf filter consumes the .so directly — and
# v3.1.0's tools/vmaf fails to link with the default meson rules: it gets
# linked with `cc` (no libstdc++) but transitively pulls in svm.cpp from
# libvmaf.a, leaving every C++ stdlib symbol unresolved.  Skipping it
# sidesteps that meson bug entirely.
RUN cd /tmp \
    && git clone --depth=1 --branch="${VMAF_TAG}" https://github.com/Netflix/vmaf.git \
    && cd vmaf/libvmaf \
    && meson setup build \
        --buildtype=release \
        -Denable_cuda=true \
        -Denable_tools=false \
        -Denable_tests=false \
        -Denable_docs=false \
    && meson install -C build \
    && ldconfig \
    && cd /tmp && rm -rf vmaf

# FFmpeg with the full codec set, pinned.
#
# --enable-gpl + --enable-nonfree pulls in x264, x265, libnpp, etc.  The
# resulting binary is non-redistributable, which is fine for a per-user
# build that never leaves the user's machine.
RUN cd /tmp \
    && git clone --depth=1 --branch="${FFMPEG_TAG}" https://github.com/FFmpeg/FFmpeg.git \
    && cd FFmpeg \
    && ./configure \
        --prefix=/usr/local \
        --enable-gpl \
        --enable-nonfree \
        --enable-version3 \
        --enable-shared \
        --disable-static \
        --disable-doc \
        --disable-debug \
        --disable-stripping \
        # NVIDIA stack
        --enable-cuda \
        --enable-cuda-nvcc \
        --enable-cuvid \
        --enable-nvenc \
        --enable-nvdec \
        --enable-ffnvcodec \
        --enable-libnpp \
        # VMAF (CUDA-enabled because libvmaf was built with -Denable_cuda)
        --enable-libvmaf \
        # AV1 software (decode + encode), to round out the hardware path.
        # libsvtav1 is intentionally absent: noble's libsvtav1-dev ships
        # headers + libs but no .pc file (Debian packaging bug), and we
        # don't actually use software AV1 encoding (we use av1_nvenc).
        # libaom remains as the reference software AV1 encoder if needed.
        --enable-libdav1d \
        --enable-libaom \
        # Other software video codecs
        --enable-libx264 \
        --enable-libx265 \
        --enable-libvpx \
        # Audio
        --enable-libopus \
        --enable-libvorbis \
        --enable-libmp3lame \
        --enable-libtheora \
        # Subtitles + image + colour-space (zscale powers HDR→SDR tonemap
        # on CPU before frames are uploaded to GPU for libvmaf_cuda).
        --enable-libass \
        --enable-libwebp \
        --enable-libzimg \
        # libfreetype/libfribidi enable the `drawtext` filter, used by
        # the integration test fixture's synthetic-clip builder (a frame
        # counter overlay is what gives idet the right amount of motion
        # signal to classify the synthesised source as progressive).
        --enable-libfreetype \
        --enable-libfribidi \
        --nvccflags="${NVCC_FLAGS}" \
    && make -j"$(nproc)" \
    && make install \
    && ldconfig \
    && cd /tmp && rm -rf FFmpeg

WORKDIR /work

# Clear the inherited /opt/nvidia/nvidia_entrypoint.sh so `podman run IMAGE
# <tool> <args>` runs the tool directly.  The base image's entrypoint just
# prints a CUDA-version banner + license boilerplate to stdout before
# exec'ing the user's command — useful for nvidia/cuda's intended
# "interactive shell + version display" use, harmful for our
# captured-stdout pipelines (every ffmpeg invocation would have to filter
# the banner out of its stderr).  CUDA env (PATH, LD_LIBRARY_PATH, CPATH)
# is already set above via ENV directives, so we lose nothing functional.
ENTRYPOINT []
